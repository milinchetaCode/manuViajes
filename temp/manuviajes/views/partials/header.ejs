<header class="header-brand py-5 px-4 shadow-md">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">

    <!-- Logo + Title -->
    <h1 class="flex items-center gap-3">
      <a href="/" class="logo-link flex items-center gap-3">
        <img 
          src="/images/logo.png" 
          alt="Logo" 
          title="Manu Figueroa Viajes" 
          class="max-h-14 w-auto object-contain" 
        />
        <span class="text-xl md:text-2xl font-bold tracking-tight text-light">
          Manu Figueroa Viajes
        </span>
      </a>
    </h1>

    <!-- Navigation ...-->
    <nav class="flex flex-col md:flex-row items-center justify-center gap-3 text-center w-full md:w-auto">
      <!-- Product buttons -->
      <a href="/hoteles" class="btn-accent <%= currentPage === 'hoteles' ? 'font-bold' : '' %>">
        <i data-feather="home" class="w-4 h-4"></i>
        Hoteles Online
      </a>
      <a href="/about" class="btn-accent <%= currentPage === 'asistencia' ? 'font-bold' : '' %>">
        <i data-feather="heart" class="w-4 h-4"></i>
        Asistencia al Viajero
      </a>
      <a href="/about" class="btn-accent <%= currentPage === 'aereos' ? 'font-bold' : '' %>">
        <i data-feather="navigation" class="w-4 h-4"></i>
        Aéreos
      </a>
    </nav>

  </div>
</header>

<!-- Local Feather Icons + header initialization -->
<script src="/js/feather.min.js" defer></script>
<script src="/js/header.js" defer></script>
