# .slugignore - Tells Render what to exclude from the slug
# This is critical to ensure public/ directory is deployed

# Development files
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env.local
.env.*.local

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temp/build directories
.cache/
.next/
dist/
build/
coverage/

# Source control
.git/
.gitignore
.github/

# Temporary
temp/
.temp/

# Do NOT exclude public/ - we need it for static files!
