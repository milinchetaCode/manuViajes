<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ManuViajes</title>
  <link rel="stylesheet" href="/styles/output.css">
  <script src="https://unpkg.com/feather-icons"></script>
</head>

<!-- inline fallback ensures navy shows immediately even before CSS loads -->
<body style="background:#1A2238; color:#F7F7FA; font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;">

  <!-- Header partial (kept as partial) -->
  <%- include('partials/header') %>

  <div class="container">

    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <!-- Use your real title here -->
        <h1 class="title">Manuel Figueroa Viajes</h1>
        <div class="divider"></div>
      </div>

      <!-- Slider -->
      <div class="hero-slider" aria-hidden="false">
        <div id="heroSlider" class="slider-inner">
          <% if (heroImages && heroImages.length) { %>
            <div id="sliderInner" class="slides">
              <% heroImages.forEach((imgUrl) => { %>
                <div class="slide">
                  <img src="<%= imgUrl %>" alt="Hero Image">
                  <div class="overlay"></div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div id="sliderInner" class="slides">
              <div class="slide">
                <img src="/images/f1.jpeg" alt="Fórmula 1">
                <div class="overlay"></div>
              </div>
            </div>
          <% } %>
        </div>

        <!-- arrows -->
        <button id="prevSlide" class="slider-arrow left" aria-label="Previous slide">&#10094;</button>
        <button id="nextSlide" class="slider-arrow right" aria-label="Next slide">&#10095;</button>
      </div>
    </section>

    <!-- Paquetes turísticos -->
    <section class="packages">
      <div class="section-head">
        <h2>
          <i data-feather="package" style="color:var(--accent);"></i>
          Paquetes turísticos
        </h2>
        <div class="divider"></div>
      </div>

      <% if (packages && packages.length) { %>
        <ul class="grid" role="list" aria-label="Paquetes">
          <% packages.filter(pkg => pkg.visible).forEach(pkg => { %>
            <li class="card" role="listitem">
              <img 
                src="<%= pkg.photoUrl && pkg.photoUrl.trim() !== '' ? pkg.photoUrl.trim() : (pkg.foto && pkg.foto.trim() !== '' ? '/images/' + pkg.foto.trim() + '.jpeg' : '/images/default.jpeg') %>"
                alt="<%= pkg.eventName %>"
              />
              <div style="display:flex; gap:8px; align-items:center;">
                <span class="badge-accent">Paquete</span>
              </div>

              <h3>
                <a href="/paquete/<%= pkg.id %>" style="color:inherit; text-decoration:none;">
                  <%= pkg.eventName %>
                </a>
              </h3>

              <p><strong>📅 Fechas:</strong> <%= pkg.availabilityDates %></p>

              <p class="price">
                <% if (pkg.ticketPrice) { %>
                  💶 u$d <%= pkg.ticketPrice.toLocaleString('es-ES') %>
                <% } else { %>
                  Precio no disponible
                <% } %>
              </p>

              <a href="/paquete/<%= pkg.id %>" class="btn-brand">Ver detalles</a>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p style="text-align:center; color:rgba(247,247,250,0.9);">No hay paquetes disponibles en este momento.</p>
      <% } %>
    </section>
  </div>

  <!-- Footer partial -->
  <%- include('partials/footer') %>

  <!-- Slider JS -->
  <script>
    feather.replace();

    const sliderInner = document.getElementById('sliderInner');
    const slides = sliderInner ? sliderInner.children : [];
    let currentIndex = 0;

    function showSlide(index){
      if (!sliderInner || slides.length === 0) return;
      sliderInner.style.transform = `translateX(-${index * 100}%)`;
    }

    document.getElementById('prevSlide')?.addEventListener('click', () => {
      if (!slides.length) return;
      currentIndex = (currentIndex - 1 + slides.length) % slides.length;
      showSlide(currentIndex);
    });

    document.getElementById('nextSlide')?.addEventListener('click', () => {
      if (!slides.length) return;
      currentIndex = (currentIndex + 1) % slides.length;
      showSlide(currentIndex);
    });

    // auto-advance
    setInterval(() => {
      if (!slides.length) return;
      currentIndex = (currentIndex + 1) % slides.length;
      showSlide(currentIndex);
    }, 5000);
  </script>
</body>
</html>
