<!DOCTYPE html>
<html lang="es">
<head>
  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="16x16" href="/images/fav1616.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/images/fav3232.png">

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Qualy Tours</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#1D4ED8',
            accent: '#22C55E',
            customRed: '#DC2626',
            darkGray: '#333333'
          }
        }
      }
    }
  </script>
  <style>
    body {
      background-color: white;
      background-image: none;
    }
    .hero-section-card {
      background-color: white !important;
      background-image: none !important;
    }
    .section-heading-blue {
      color: #333333 !important;
    }
    .section-description-blue {
      color: rgba(0, 51, 102, 0.8);
    }
    .hover\:shadow-xl:hover {
      box-shadow-lg: 0 10px 15px -3px rgba(220, 38, 38, 0.3),
                  0 4px 6px -2px rgba(220, 38, 38, 0.2) !important;
    }
    .hover\:border-accent:hover {
      border-color: #DC2626 !important;
    }
  </style>
</head>
<body class="text-gray-800 font-sans">

  <%- include('partials/header') %>

  <!-- HERO -->
  <section class="relative mb-12 hero-section-card bg-gradient-to-r from-white to-blue-50">
    <div class="px-6 py-12 md:py-20">
      <div class="max-w-6xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 tracking-tight text-darkGray leading-snug">
          Viví el deporte en vivo
        </h2>
        <div class="w-16 h-1 mx-auto bg-customRed rounded mt-2 mb-6"></div>
      </div>

      <!-- Banner clickeable -->
      <div class="relative w-full flex justify-center">
        <div class="relative w-full sm:w-4/5 md:w-3/4 lg:w-3/4">
          <a href="/f1" class="block relative rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-500">
            <img src="/images/f1.jpeg" alt="Fórmula 1" class="w-full h-80 object-cover" />
            <div class="absolute inset-0 bg-black bg-opacity-40 flex flex-col justify-center items-center text-center text-white px-4">
              <h3 class="text-4xl sm:text-5xl font-extrabold mb-4">Fórmula 1</h3>
              <span
                class="inline-block text-lg font-semibold text-white bg-customRed border border-white px-6 py-3 rounded-full shadow-md 
                       hover:bg-red-700 hover:shadow-xl hover:scale-[1.04] transform transition-all duration-300">
                Encontrá tu entrada
              </span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="content-container px-4 md:px-6 lg:px-8">
    <!-- Paquetes turísticos -->
    <section class="mb-12">
      <div class="text-center mb-8">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold flex items-center justify-center gap-2 section-heading-blue">
          <i data-feather="package" class="w-6 h-6 text-accent"></i> Paquetes turísticos
        </h2>
        <div class="w-16 h-1 mx-auto bg-customRed rounded mt-2 mb-6"></div>
      </div>

      <% if (packages && packages.length) { %>
        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <% packages.filter(pkg => pkg.visible).forEach(pkg => { %>
            <li class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100 transition-all duration-300 hover:border-accent hover:shadow-xl">
              <img 
                src="<%= pkg.photoUrl && pkg.photoUrl.trim() !== '' ? pkg.photoUrl.trim() : (pkg.foto && pkg.foto.trim() !== '' ? '/images/' + pkg.foto.trim() + '.jpeg' : '/images/default.jpeg') %>"
                alt="<%= pkg.eventName %>"
                class="w-full h-44 object-cover rounded-2xl shadow-sm border border-gray-200 mb-4"
              />
              <span class="inline-block text-xs bg-red-100 text-red-800 font-semibold px-2 py-1 rounded-full mb-2">Paquete</span>
              <h3 class="text-xl font-bold tracking-tight text-gray-900 mb-2">
                <a href="/paquete/<%= pkg.id %>" class="hover:text-accent transition-colors">
                  <%= pkg.eventName %>
                </a>
              </h3>
              <p class="text-sm text-gray-700 mb-1"><strong>📅 Fechas:</strong> <%= pkg.availabilityDates %></p>
              <p class="text-lg font-bold text-customRed mt-3">
                <% if (pkg.ticketPrice) { %>
                  💶 u$d <%= pkg.ticketPrice.toLocaleString('es-ES') %>
                <% } else { %>
                  Precio no disponible
                <% } %>
              </p>
              <a href="/paquete/<%= pkg.id %>" class="inline-block mt-3 text-sm text-white bg-customRed px-4 py-2 rounded-full hover:bg-red-700 transition-all shadow-md hover:shadow-lg">
                Ver detalles
              </a>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="text-center text-gray-600">No hay paquetes disponibles en este momento.</p>
      <% } %>
    </section>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
