<header class="bg-brand py-5 px-4 shadow-md">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">

    <!-- Logo -->
    <h1 class="text-2xl font-bold flex items-center gap-2">
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity duration-200">
        <img 
          src="/images/logo.png" 
          alt="Logo" 
          title="Manuel Figueroa Viajes" 
          class="max-h-14 w-auto object-contain" 
        />
      </a>
    </h1>

    <!-- Hoteles Online -->
    <div class="my-2 md:my-0 flex justify-center w-full md:w-auto">
      <a href="/hoteles" 
         class="btn-accent font-semibold text-base px-6 py-2 rounded-full shadow-lg cursor-pointer hover:bg-accent/90 transition-colors">
        Hoteles Online
      </a>
    </div>

    <!-- Navigation -->
    <nav class="flex flex-col md:flex-row items-center gap-3 text-center">
      <a href="/about" 
         class="btn-accent text-sm px-3 py-1 rounded-full shadow-lg cursor-pointer hover:bg-accent/90 transition-colors <%= currentPage === 'about' ? 'font-bold' : '' %>">
        Experiencia
      </a>
    </nav>

  </div>
</header>
