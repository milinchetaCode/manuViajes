<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Panel de Administración - Paquetes</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/feather-icons"></script>
  <style>
    .save-button-container {
      position: sticky;
      bottom: 10px;
      background: white;
      padding: 1rem 0;
      box-shadow-lg: 0 -4px 6px rgba(0,0,0,0.1);
      z-index: 50;
      max-width: 80rem;
      margin: 0 auto;
    }

    /* Fade-in animation for package cards */
    .fade-in {
      @apply opacity-0 transform translate-y-4 transition-all duration-700;
    }
    .fade-in.visible {
      @apply opacity-100 translate-y-0;
    }
  </style>
</head>
<body class="bg-gray-100 min-h-screen p-6 font-sans text-gray-800">

  <!-- Header -->
  <header class="flex justify-between items-center mb-6 bg-white shadow-md rounded-lg p-4">
    <h1 class="text-2xl font-bold text-green-800">Panel de Administración - Paquetes</h1>

    <div class="flex items-center space-x-4">
      <a href="/admin/fotos">
        <button type="button"
          class="bg-brand hover:bg-blue-700 text-white font-bold px-4 py-2 rounded shadow-lg flex items-center space-x-2 transition-transform active:scale-95 focus:outline-none focus:ring-4 focus:ring-blue-400">
          <i data-feather="image" class="w-4 h-4"></i>
          <span>Galería de Fotos</span>
        </button>
      </a>

      <a href="/admin/logout" class="text-sm text-red-600 hover:underline">Cerrar sesión</a>
    </div>
  </header>

  <form action="/admin/panel" method="POST" class="space-y-6 max-w-6xl mx-auto">

    <% paquetes.forEach((pkg) => { %>
      <div class="fade-in bg-white rounded-lg shadow-md p-6">
        <h2 class="text-lg font-semibold mb-4 text-green-700">
          Paquete ID: <span class="font-mono text-gray-600"><%= pkg.id %></span> — <%= pkg.eventName %>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

          <div>
            <label class="block mb-1 font-semibold" for="eventName-<%= pkg.id %>">Nombre del Evento</label>
            <input
              id="eventName-<%= pkg.id %>"
              type="text"
              name="paquetes[<%= pkg.id %>][eventName]"
              value="<%= pkg.eventName %>"
              required
              class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
            />
          </div>

          <div>
            <label class="block mb-1 font-semibold" for="ticketPrice-<%= pkg.id %>">Precio (u$d)</label>
            <input
              id="ticketPrice-<%= pkg.id %>"
              type="number"
              name="paquetes[<%= pkg.id %>][ticketPrice]"
              value="<%= pkg.ticketPrice %>"
              min="0"
              step="0.01"
              required
              class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
            />
          </div>

          <div class="md:col-span-2">
            <label class="block mb-1 font-semibold" for="flightInfo-<%= pkg.id %>">Información Vuelo</label>
            <textarea
              id="flightInfo-<%= pkg.id %>"
              name="paquetes[<%= pkg.id %>][flightInfo]"
              rows="2"
              class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500 resize-y"
            ><%= pkg.flightInfo %></textarea>
          </div>

          <div class="md:col-span-2">
            <label class="block mb-1 font-semibold" for="hotelInfo-<%= pkg.id %>">Información Hotel</label>
            <textarea
              id="hotelInfo-<%= pkg.id %>"
              name="paquetes[<%= pkg.id %>][hotelInfo]"
              rows="2"
              class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500 resize-y"
            ><%= pkg.hotelInfo %></textarea>
          </div>

          <div class="md:col-span-2">
            <label class="block mb-1 font-semibold" for="description-<%= pkg.id %>">Descripción</label>
            <textarea
              id="description-<%= pkg.id %>"
              name="paquetes[<%= pkg.id %>][description]"
              rows="5"
              class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500 resize-y"
            ><%= pkg.description %></textarea>
          </div>

          <div>
            <label class="block mb-1 font-semibold" for="availabilityDates-<%= pkg.id %>">Fechas Disponibles</label>
            <input
              id="availabilityDates-<%= pkg.id %>"
              type="text"
              name="paquetes[<%= pkg.id %>][availabilityDates]"
              value="<%= pkg.availabilityDates %>"
              class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
            />
          </div>

          <div class="flex items-center space-x-2 mt-4">
            <input
              id="visible-<%= pkg.id %>"
              type="checkbox"
              name="paquetes[<%= pkg.id %>][visible]"
              value="1"
              <%= pkg.visible ? 'checked' : '' %>
              class="rounded border-gray-300 text-green-500 focus:ring-green-500"
            />
            <label for="visible-<%= pkg.id %>" class="font-semibold select-none">Visible</label>
          </div>

          <div class="flex flex-col">
            <label class="block mb-1 font-semibold" for="photo-<%= pkg.id %>">Foto</label>
            <select
              id="photo-<%= pkg.id %>"
              name="paquetes[<%= pkg.id %>][foto]"
              class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
            >
              <option value="">-- Seleccionar --</option>
              <option value="f1" <%= pkg.foto === 'f1' ? 'selected' : '' %>>f1</option>
              <option value="basquet" <%= pkg.foto === 'basquet' ? 'selected' : '' %>>basquet</option>
              <option value="tenis" <%= pkg.foto === 'tenis' ? 'selected' : '' %>>tenis</option>
              <option value="futbol" <%= pkg.foto === 'futbol' ? 'selected' : '' %>>futbol</option>
              <option value="playa" <%= pkg.foto === 'playa' ? 'selected' : '' %>>playa</option>
              <option value="ciudad" <%= pkg.foto === 'ciudad' ? 'selected' : '' %>>ciudad</option>
            </select>

            <label class="block mt-3 mb-1 font-semibold" for="photoUrl-<%= pkg.id %>">URL de Imagen (copiar de galeria de fotos)</label>
            <div class="flex items-center space-x-2">
              <input
                id="photoUrl-<%= pkg.id %>"
                type="url"
                name="paquetes[<%= pkg.id %>][photoUrl]"
                value="<%= pkg.photoUrl || '' %>"
                placeholder="https://example.com/imagen.jpg"
                class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
              />
              <% if (pkg.photoUrl) { %>
                <img src="<%= pkg.photoUrl %>" alt="thumbnail" class="w-16 h-16 object-cover rounded border border-gray-300"/>
              <% } %>
            </div>
          </div>

        </div>
      </div>
    <% }); %>

    <!-- Eventos Destacados -->
    <div class="bg-white rounded-lg shadow-md p-6 mt-8 max-w-6xl mx-auto">
      <h2 class="text-lg font-semibold mb-4 text-green-700">Eventos Destacados</h2>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <% destacados.forEach((destacado, i) => { %>
          <div class="flex flex-col">
            <label class="text-sm font-medium mb-1" for="destacadoId-<%= i %>">Evento ID</label>
            <input
              type="text"
              id="destacadoId-<%= i %>"
              name="destacados[<%= i %>][id]"
              maxlength="30"
              class="rounded border border-gray-300 px-3 py-2 mb-2 focus:outline-none focus:ring-2 focus:ring-green-500"
              value="<%= destacado.id %>"
            />
            <label class="text-sm font-medium mb-1" for="destacadoPhoto-<%= i %>">Imagen</label>
            <select
              id="destacadoPhoto-<%= i %>"
              name="destacados[<%= i %>][foto]"
              class="rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
            >
              <option value="" <%= destacado.foto === '' ? 'selected' : '' %>>-- Seleccionar --</option>
              <option value="f1" <%= destacado.foto === 'f1' ? 'selected' : '' %>>f1</option>
              <option value="basquet" <%= destacado.foto === 'basquet' ? 'selected' : '' %>>basquet</option>
              <option value="tenis" <%= destacado.foto === 'tenis' ? 'selected' : '' %>>tenis</option>
              <option value="futbol" <%= destacado.foto === 'futbol' ? 'selected' : '' %>>futbol</option>
              <option value="playa" <%= destacado.foto === 'playa' ? 'selected' : '' %>>playa</option>
              <option value="ciudad" <%= destacado.foto === 'ciudad' ? 'selected' : '' %>>ciudad</option>
            </select>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="save-button-container text-right">
      <button
        type="submit"
        class="bg-green-700 hover:bg-green-800 text-white font-bold px-8 py-3 rounded shadow-lg flex items-center justify-center space-x-2 transition-transform active:scale-95 focus:outline-none focus:ring-4 focus:ring-green-400"
      >
        <i data-feather="save" class="w-4 h-4"></i>
        <span>Guardar Cambios</span>
      </button>
    </div>
  </form>

  <script>
    // Fade-in animation for packages
    window.addEventListener('DOMContentLoaded', () => {
      const cards = document.querySelectorAll('.fade-in');
      cards.forEach((card, index) => {
        setTimeout(() => card.classList.add('visible'), index * 100);
      });

      // Initialize feather icons
      feather.replace();
    });
  </script>

</body>
</html>
