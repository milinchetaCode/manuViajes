<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel de Administración - Paquetes</title>
  <link rel="stylesheet" href="/styles/output.css">
  <style>
    .save-button-container {
      position: sticky;
      bottom: 0;
      background: white;
      padding: 1rem 0;
      box-shadow: 0 -4px 6px rgba(0,0,0,0.1);
      z-index: 50;
      max-width: 72rem;
      margin: 0 auto;
    }
  </style>
</head>
<body class="bg-gray-100 min-h-screen font-sans text-gray-800">

  <!-- Header -->
  <header class="bg-white py-5 px-4 shadow-md mb-8">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <h1 class="text-2xl font-bold text-green-800">Panel de Administración - Paquetes</h1>
      <div class="flex items-center gap-4">
        <a href="/admin/fotos" class="bg-accent text-white font-semibold px-4 py-2 rounded shadow hover:bg-accent/90 transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Galería de Fotos
        </a>
        <a href="/admin/logout" class="text-red-600 font-semibold hover:underline">Cerrar sesión</a>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-4 mb-20"> <!-- extra bottom margin for sticky button -->

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
      <h2 class="text-xl font-bold text-gray-700">Listado de Paquetes</h2>
      <button type="button" id="btn-add-package" class="bg-green-600 hover:bg-green-700 text-white font-semibold px-4 py-2 rounded-lg shadow-md transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Agregar Nuevo Paquete
      </button>
    </div>

    <form action="/admin/panel" method="POST" class="space-y-8">
      <div id="packages-container" class="space-y-8">
        <% paquetes.forEach((pkg) => { %>
        <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-200 package-card" data-package-id="<%= pkg.id %>">
          <div class="flex flex-wrap justify-between items-center mb-4 gap-4">
            <div class="flex flex-wrap items-center gap-4">
              <h2 class="text-xl font-semibold text-green-700">
                Paquete ID: <span class="font-mono text-gray-600"><%= pkg.id %></span> — <%= pkg.eventName %>
              </h2>
              <div class="flex items-center space-x-2 bg-gray-50 px-3 py-1 rounded-full border border-gray-200">
                <input id="visible-<%= pkg.id %>" type="checkbox" name="paquetes[<%= pkg.id %>][visible]" value="1" <%= pkg.visible ? 'checked' : '' %>
                  class="rounded border-gray-300 text-accent focus:ring-accent"/>
                <label for="visible-<%= pkg.id %>" class="font-semibold text-sm select-none text-gray-700">Visible</label>
              </div>
            </div>
            <button type="button" class="btn-delete-package bg-red-100 hover:bg-red-200 text-red-600 p-2 rounded-lg transition-colors" title="Eliminar Paquete">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            </button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <!-- Event Name -->
            <div>
              <label class="block mb-1 font-semibold" for="eventName-<%= pkg.id %>">Nombre del Evento</label>
              <input id="eventName-<%= pkg.id %>" type="text" name="paquetes[<%= pkg.id %>][eventName]" value="<%= pkg.eventName %>" required
                class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
            </div>

            <!-- Continent -->
            <div>
              <label class="block mb-1 font-semibold" for="continent-<%= pkg.id %>">Continente</label>
              <input id="continent-<%= pkg.id %>" type="text" name="paquetes[<%= pkg.id %>][continent]" value="<%= pkg.continent || '' %>"
                class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
            </div>

            <!-- Ticket Price -->
            <div>
              <label class="block mb-1 font-semibold" for="ticketPrice-<%= pkg.id %>">Precio</label>
              <input id="ticketPrice-<%= pkg.id %>" 
                     type="text" 
                     name="paquetes[<%= pkg.id %>][ticketPrice]" 
                     value="<%= pkg.ticketPrice %>" 
                     required
                     class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
            </div>


            <!-- Flight Info -->
            <div class="md:col-span-2">
              <label class="block mb-1 font-semibold" for="flightInfo-<%= pkg.id %>">Información Vuelo</label>
              <textarea id="flightInfo-<%= pkg.id %>" name="paquetes[<%= pkg.id %>][flightInfo]" rows="2"
                class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none resize-y"><%= pkg.flightInfo %></textarea>
            </div>

            <!-- Hotel Info -->
            <div class="md:col-span-2">
              <label class="block mb-1 font-semibold" for="hotelInfo-<%= pkg.id %>">Información Hotel</label>
              <textarea id="hotelInfo-<%= pkg.id %>" name="paquetes[<%= pkg.id %>][hotelInfo]" rows="2"
                class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none resize-y"><%= pkg.hotelInfo %></textarea>
            </div>

            <!-- Description -->
            <div class="md:col-span-2">
              <label class="block mb-1 font-semibold" for="description-<%= pkg.id %>">Descripción</label>
              <textarea id="description-<%= pkg.id %>" name="paquetes[<%= pkg.id %>][description]" rows="5"
                class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none resize-y"><%= pkg.description %></textarea>
            </div>

            <!-- Availability Dates -->
            <div>
              <label class="block mb-1 font-semibold" for="availabilityDates-<%= pkg.id %>">Fechas Disponibles</label>
              <input id="availabilityDates-<%= pkg.id %>" type="text" name="paquetes[<%= pkg.id %>][availabilityDates]" value="<%= pkg.availabilityDates %>"
                class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
            </div>

            <!-- Photo -->
            <div>
              <input type="hidden" name="paquetes[<%= pkg.id %>][foto]" value="<%= pkg.foto || '' %>"/>

              <!-- Photo URL -->
              <label class="block mb-1 font-semibold" for="photoUrl-<%= pkg.id %>">URL de Imagen (copiar de galería de fotos)</label>
              <div class="flex items-center gap-2">
                <input id="photoUrl-<%= pkg.id %>" type="url" name="paquetes[<%= pkg.id %>][photoUrl]" value="<%= pkg.photoUrl || '' %>"
                  placeholder="https://example.com/imagen.jpg"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
                <% if (pkg.photoUrl) { %>
                  <img src="<%= pkg.photoUrl %>" alt="thumbnail" class="w-16 h-16 object-cover rounded border border-gray-300"/>
                <% } %>
              </div>
            </div>

          </div>
        </div>
        <% }); %>
      </div>

      <!-- Sticky Save Button -->
      <div class="save-button-container text-right">
        <button type="submit" class="bg-accent hover:bg-accent/90 text-white font-bold px-8 py-3 rounded-full shadow-lg transition-colors flex items-center gap-2 justify-center">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/>
          </svg>
          Guardar Cambios
        </button>
      </div>

    </form>
  </main>

  <!-- HTML Template for dynamic new package creation -->
  <template id="package-card-template">
    <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-200 package-card" data-package-id="__ID__">
      <div class="flex flex-wrap justify-between items-center mb-4 gap-4">
        <div class="flex flex-wrap items-center gap-4">
          <h2 class="text-xl font-semibold text-green-700">
            Nuevo Paquete: <span class="font-mono text-gray-600">__ID__</span>
          </h2>
          <div class="flex items-center space-x-2 bg-gray-50 px-3 py-1 rounded-full border border-gray-200">
            <input id="visible-__ID__" type="checkbox" name="paquetes[__ID__][visible]" value="1" checked
              class="rounded border-gray-300 text-accent focus:ring-accent"/>
            <label for="visible-__ID__" class="font-semibold text-sm select-none text-gray-700">Visible</label>
          </div>
        </div>
        <button type="button" class="btn-delete-package bg-red-100 hover:bg-red-200 text-red-600 p-2 rounded-lg transition-colors" title="Eliminar Paquete">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        </button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <!-- Event Name -->
        <div>
          <label class="block mb-1 font-semibold" for="eventName-__ID__">Nombre del Evento</label>
          <input id="eventName-__ID__" type="text" name="paquetes[__ID__][eventName]" value="" required
            class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
        </div>

        <!-- Continent -->
        <div>
          <label class="block mb-1 font-semibold" for="continent-__ID__">Continente</label>
          <input id="continent-__ID__" type="text" name="paquetes[__ID__][continent]" value=""
            class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
        </div>

        <!-- Ticket Price -->
        <div>
          <label class="block mb-1 font-semibold" for="ticketPrice-__ID__">Precio</label>
          <input id="ticketPrice-__ID__"
                 type="text"
                 name="paquetes[__ID__][ticketPrice]"
                 value=""
                 required
                 class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
        </div>

        <!-- Flight Info -->
        <div class="md:col-span-2">
          <label class="block mb-1 font-semibold" for="flightInfo-__ID__">Información Vuelo</label>
          <textarea id="flightInfo-__ID__" name="paquetes[__ID__][flightInfo]" rows="2"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none resize-y"></textarea>
        </div>

        <!-- Hotel Info -->
        <div class="md:col-span-2">
          <label class="block mb-1 font-semibold" for="hotelInfo-__ID__">Información Hotel</label>
          <textarea id="hotelInfo-__ID__" name="paquetes[__ID__][hotelInfo]" rows="2"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none resize-y"></textarea>
        </div>

        <!-- Description -->
        <div class="md:col-span-2">
          <label class="block mb-1 font-semibold" for="description-__ID__">Descripción</label>
          <textarea id="description-__ID__" name="paquetes[__ID__][description]" rows="5"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none resize-y"></textarea>
        </div>

        <!-- Availability Dates -->
        <div>
          <label class="block mb-1 font-semibold" for="availabilityDates-__ID__">Fechas Disponibles</label>
          <input id="availabilityDates-__ID__" type="text" name="paquetes[__ID__][availabilityDates]" value=""
            class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
        </div>

        <!-- Photo -->
        <div>
          <input type="hidden" name="paquetes[__ID__][foto]" value=""/>

          <!-- Photo URL -->
          <label class="block mb-1 font-semibold" for="photoUrl-__ID__">URL de Imagen (copiar de galería de fotos)</label>
          <div class="flex items-center gap-2">
            <input id="photoUrl-__ID__" type="url" name="paquetes[__ID__][photoUrl]" value=""
              placeholder="https://example.com/imagen.jpg"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
          </div>
        </div>

      </div>
    </div>
  </template>

  <!-- External JavaScript file (CSP compliant) -->
  <script src="/js/admin-panel.js"></script>
</body>
</html>
