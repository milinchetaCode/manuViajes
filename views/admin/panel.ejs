<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel de Administración - Paquetes</title>
  <link rel="stylesheet" href="/styles/output.css">
  <script src="https://unpkg.com/feather-icons"></script>
  <style>
    .save-button-container {
      position: sticky;
      bottom: 0;
      background: white;
      padding: 1rem 0;
      box-shadow: 0 -4px 6px rgba(0,0,0,0.1);
      z-index: 50;
      max-width: 72rem;
      margin: 0 auto;
    }
  </style>
</head>
<body class="bg-gray-100 min-h-screen font-sans text-gray-800">

  <!-- Header -->
  <header class="bg-white py-5 px-4 shadow-md mb-8">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <h1 class="text-2xl font-bold text-green-800">Panel de Administración - Paquetes</h1>
      <div class="flex items-center gap-4">
        <a href="/admin/fotos" class="bg-accent text-white font-semibold px-4 py-2 rounded shadow hover:bg-accent/90 transition-colors flex items-center gap-2">
          <i data-feather="image" class="w-4 h-4"></i> Galería de Fotos
        </a>
        <a href="/admin/logout" class="text-red-600 font-semibold hover:underline">Cerrar sesión</a>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-4 mb-20"> <!-- extra bottom margin for sticky button -->

    <form action="/admin/panel" method="POST" class="space-y-8">

      <% paquetes.forEach((pkg) => { %>
      <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-200">
        <h2 class="text-xl font-semibold mb-4 text-green-700">
          Paquete ID: <span class="font-mono text-gray-600"><%= pkg.id %></span> — <%= pkg.eventName %>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

          <!-- Event Name -->
          <div>
            <label class="block mb-1 font-semibold" for="eventName-<%= pkg.id %>">Nombre del Evento</label>
            <input id="eventName-<%= pkg.id %>" type="text" name="paquetes[<%= pkg.id %>][eventName]" value="<%= pkg.eventName %>" required
              class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
          </div>

         <!-- Ticket Price -->
<div>
  <label class="block mb-1 font-semibold" for="ticketPrice-<%= pkg.id %>">Precio</label>
  <input id="ticketPrice-<%= pkg.id %>" 
         type="text" 
         name="paquetes[<%= pkg.id %>][ticketPrice]" 
         value="<%= pkg.ticketPrice %>" 
         required
         class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
</div>


          <!-- Flight Info -->
          <div class="md:col-span-2">
            <label class="block mb-1 font-semibold" for="flightInfo-<%= pkg.id %>">Información Vuelo</label>
            <textarea id="flightInfo-<%= pkg.id %>" name="paquetes[<%= pkg.id %>][flightInfo]" rows="2"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none resize-y"><%= pkg.flightInfo %></textarea>
          </div>

          <!-- Hotel Info -->
          <div class="md:col-span-2">
            <label class="block mb-1 font-semibold" for="hotelInfo-<%= pkg.id %>">Información Hotel</label>
            <textarea id="hotelInfo-<%= pkg.id %>" name="paquetes[<%= pkg.id %>][hotelInfo]" rows="2"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none resize-y"><%= pkg.hotelInfo %></textarea>
          </div>

          <!-- Description -->
          <div class="md:col-span-2">
            <label class="block mb-1 font-semibold" for="description-<%= pkg.id %>">Descripción</label>
            <textarea id="description-<%= pkg.id %>" name="paquetes[<%= pkg.id %>][description]" rows="5"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none resize-y"><%= pkg.description %></textarea>
          </div>

          <!-- Availability Dates -->
          <div>
            <label class="block mb-1 font-semibold" for="availabilityDates-<%= pkg.id %>">Fechas Disponibles</label>
            <input id="availabilityDates-<%= pkg.id %>" type="text" name="paquetes[<%= pkg.id %>][availabilityDates]" value="<%= pkg.availabilityDates %>"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
          </div>

          <!-- Visible -->
          <div class="flex items-center space-x-2 mt-4">
            <input id="visible-<%= pkg.id %>" type="checkbox" name="paquetes[<%= pkg.id %>][visible]" value="1" <%= pkg.visible ? 'checked' : '' %>
              class="rounded border-gray-300 text-accent focus:ring-accent"/>
            <label for="visible-<%= pkg.id %>" class="font-semibold select-none">Visible</label>
          </div>

          <!-- Photo -->
          <div>
            <label class="block mb-1 font-semibold" for="photo-<%= pkg.id %>">Foto</label>
            <select id="photo-<%= pkg.id %>" name="paquetes[<%= pkg.id %>][foto]"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none">
              <option value="">-- Seleccionar --</option>
              <option value="f1" <%= pkg.foto === 'f1' ? 'selected' : '' %>>f1</option>
              <option value="basquet" <%= pkg.foto === 'basquet' ? 'selected' : '' %>>basquet</option>
              <option value="tenis" <%= pkg.foto === 'tenis' ? 'selected' : '' %>>tenis</option>
              <option value="futbol" <%= pkg.foto === 'futbol' ? 'selected' : '' %>>futbol</option>
              <option value="playa" <%= pkg.foto === 'playa' ? 'selected' : '' %>>playa</option>
              <option value="ciudad" <%= pkg.foto === 'ciudad' ? 'selected' : '' %>>ciudad</option>
            </select>

            <!-- Photo URL -->
            <label class="block mt-3 mb-1 font-semibold" for="photoUrl-<%= pkg.id %>">URL de Imagen (copiar de galería de fotos)</label>
            <div class="flex items-center gap-2">
              <input id="photoUrl-<%= pkg.id %>" type="url" name="paquetes[<%= pkg.id %>][photoUrl]" value="<%= pkg.photoUrl || '' %>"
                placeholder="https://example.com/imagen.jpg"
                class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-accent focus:outline-none"/>
              <% if (pkg.photoUrl) { %>
                <img src="<%= pkg.photoUrl %>" alt="thumbnail" class="w-16 h-16 object-cover rounded border border-gray-300"/>
              <% } %>
            </div>
          </div>

        </div>
      </div>
      <% }); %>

      <!-- Sticky Save Button -->
      <div class="save-button-container text-right">
        <button type="submit" class="bg-accent hover:bg-accent/90 text-white font-bold px-8 py-3 rounded-full shadow-lg transition-colors">
          <i data-feather="save" class="w-4 h-4 inline"></i> Guardar Cambios
        </button>
      </div>

    </form>
  </main>

  <script>
    feather.replace();
  </script>
</body>
</html>
