<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Manuel Figueroa Viajes</title>

  <!-- Tailwind compiled CSS -->
  <link rel="stylesheet" href="/styles/output.css">
  <!-- Theme overrides -->
  <link rel="stylesheet" href="/styles/theme.css">
</head>
<body class="font-sans bg-[var(--bg)] text-[var(--text)]">

  <!-- Navbar -->
  <%- include('partials/header') %>

  <!-- Login content -->
  <section class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-lg p-8 space-y-6 text-[var(--card-text)]">
      <h2 class="text-center text-3xl font-extrabold text-[var(--brand)]">
        Panel de Administración
      </h2>

      <% if (error) { %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
          <strong class="font-bold">Error: </strong>
          <span class="block sm:inline"><%= error %></span>
        </div>
      <% } %>

      <form class="mt-8 space-y-6" action="/admin/login" method="POST" autocomplete="off">
        <div class="rounded-md shadow-sm space-y-4">
          <div>
            <label for="username" class="sr-only">Usuario</label>
            <input id="username" name="username" type="text" required autocomplete="username"
              class="appearance-none rounded-md block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-[var(--card-text)] focus:outline-none focus:ring-[var(--brand)] focus:border-[var(--brand)] sm:text-sm"
              placeholder="Usuario" autofocus>
          </div>
          <div>
            <label for="password" class="sr-only">Contraseña</label>
            <input id="password" name="password" type="password" required autocomplete="current-password"
              class="appearance-none rounded-md block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-[var(--card-text)] focus:outline-none focus:ring-[var(--brand)] focus:border-[var(--brand)] sm:text-sm"
              placeholder="Contraseña">
          </div>
        </div>

        <div>
          <button type="submit" class="btn-accent w-full py-2 px-4 font-semibold rounded-md text-[var(--brand)] hover:bg-[var(--brand)] hover:text-[var(--text)] transition">
            Ingresar
          </button>
        </div>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <%- include('partials/footer') %>

</body>
</html>
