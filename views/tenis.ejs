<%- include('partials/header') %> 
<!DOCTYPE html> 
<html lang="es"> 
<head> 
  <meta charset="UTF-8" /> 
  <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
  <title>Tenis Tickets - Qualy Tours</title> 
  <script src="https://cdn.tailwindcss.com"></script> 
  <script> 
    tailwind.config = { 
      theme: { 
        extend: { 
          colors: { primary: '#1D4ED8', accent: '#22C55E' } 
        } 
      } 
    } 
  </script> 
</head> 
<body class="text-gray-800 font-sans bg-white"> 
<div class="content-container px-4 py-8"> 
  <h1 class="text-3xl font-bold text-center mb-8 text-brand">Tenis Tickets</h1> 

  <% if (!Array.isArray(events) || events.length === 0) { %> 
    <p class="text-center text-gray-600 italic">No events found.</p> 
  <% } else { %> 
    <ul id="events-list" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6"> 
      <% events.forEach(event => { %> 
        <li class="event-item hidden bg-white rounded-2xl shadow-md hover:shadow-lg transition border border-gray-200 p-4 flex flex-col"> 
          <img src="<%= event.image_url || '/images/tenis.jpeg' %>" alt="<%= event.event_name || 'Evento sin nombre' %>" class="w-full h-40 object-cover rounded-md mb-3" /> 
          <h3 class="text-xl font-semibold text-brand mb-2"><%= event.event_name || 'Evento sin nombre' %></h3> 
          <p class="text-sm text-gray-600 mb-1"> 
            📅 <%= event.date_start ? new Date(event.date_start).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : 'Fecha no disponible' %> 
            🕒 <%= event.date_start ? new Date(event.date_start).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) : '' %> - 
            <%= event.date_stop ? new Date(event.date_stop).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) : '' %> 
          </p> 
          <p class="text-sm text-gray-500 mb-2"> 
            📍 <%= event.venue_name || 'Lugar no especificado' %> <% if(event.city) { %> - <%= event.city %> <% } %> 
          </p> 
          <p class="text-sm text-green-700 font-semibold mb-3">
            💶
            <% if(event.min_ticket_price_eur && event.max_ticket_price_eur) { %>
              €<%= event.min_ticket_price_eur %> - €<%= event.max_ticket_price_eur %>
            <% } else if(event.min_ticket_price_eur) { %>
              €<%= event.min_ticket_price_eur %>
            <% } else { %>
              No disponible
            <% } %>
          </p>
          <a href="/event/<%= event.event_id %>" class="mt-auto inline-block text-sm text-white bg-accent px-4 py-2 rounded hover:bg-brand text-center">Ver detalles</a> 
        </li> 
      <% }) %> 
    </ul> 

    <!-- Paginación -->
    <div id="pagination" class="flex justify-center mt-6 gap-2 flex-wrap"></div>

    <script>
      const itemsPerPage = 6;
      let currentPage = 1;
      const events = document.querySelectorAll('.event-item');
      const totalPages = Math.ceil(events.length / itemsPerPage);
      const maxButtons = 5; // Máximo botones numéricos visibles

      function showPage(page) {
        const start = (page - 1) * itemsPerPage;
        const end = start + itemsPerPage;
        events.forEach((el, i) => el.classList.toggle('hidden', i < start || i >= end));
        renderPagination();
      }

      function renderPagination() {
        const container = document.getElementById('pagination');
        container.innerHTML = '';

        // Botón Anterior
        const prevBtn = document.createElement('button');
        prevBtn.textContent = 'Anterior';
        prevBtn.className = 'bg-accent text-white px-3 py-1 rounded hover:bg-brand';
        prevBtn.disabled = currentPage === 1;
        prevBtn.addEventListener('click', () => { currentPage--; showPage(currentPage); });
        container.appendChild(prevBtn);

        let startPage = Math.max(1, currentPage - Math.floor(maxButtons / 2));
        let endPage = Math.min(totalPages, startPage + maxButtons - 1);
        if (endPage - startPage < maxButtons - 1) startPage = Math.max(1, endPage - maxButtons + 1);

        if (startPage > 1) {
          container.appendChild(createPageButton(1));
          if (startPage > 2) container.appendChild(createEllipsis());
        }

        for (let i = startPage; i <= endPage; i++) {
          container.appendChild(createPageButton(i));
        }

        if (endPage < totalPages) {
          if (endPage < totalPages - 1) container.appendChild(createEllipsis());
          container.appendChild(createPageButton(totalPages));
        }

        // Botón Siguiente
        const nextBtn = document.createElement('button');
        nextBtn.textContent = 'Siguiente';
        nextBtn.className = 'bg-accent text-white px-3 py-1 rounded hover:bg-brand';
        nextBtn.disabled = currentPage === totalPages;
        nextBtn.addEventListener('click', () => { currentPage++; showPage(currentPage); });
        container.appendChild(nextBtn);
      }

      function createPageButton(pageNum) {
        const btn = document.createElement('button');
        btn.textContent = pageNum;
        btn.className = `px-3 py-1 rounded ${pageNum === currentPage ? 'bg-brand text-white' : 'bg-gray-200'}`;
        btn.addEventListener('click', () => { currentPage = pageNum; showPage(currentPage); });
        return btn;
      }

      function createEllipsis() {
        const span = document.createElement('span');
        span.textContent = '...';
        span.className = 'px-2 py-1';
        return span;
      }

      showPage(currentPage);
    </script>
  <% } %>
</div> 
</body> 
</html> 
<%- include('partials/footer') %>
