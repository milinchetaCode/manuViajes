<% layout('layout') -%>
<h2 class="text-2xl font-bold mb-4">Comprar entradas para <%= event.name %></h2>
<form action="/purchase" method="POST" class="space-y-4">
  <input type="hidden" name="eventId" value="<%= event.id %>" />
  <div>
    <label class="block">Tu nombre:</label>
    <input type="text" name="name" class="w-full p-2 border rounded" required />
  </div>
  <button type="submit" class="bg-brand text-white px-4 py-2 rounded">Confirmar compra</button>
</form>