<%- include('partials/header') %>

<section class="max-w-6xl mx-auto px-4 py-10">
  <h2 class="text-3xl font-bold text-center text-brand mb-6">
    Resultados de búsqueda para: "<%= query %>"
  </h2>

  <% if (events.length === 0) { %>
    <p class="text-center text-gray-600">No se encontraron eventos.</p>
  <% } else { %>
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% events.forEach(event => { %>
        <li class="bg-white p-4 rounded-2xl shadow-lg hover:shadow-lg transition border border-gray-200">
          <img src="/images/hero.jpeg" alt="<%= event.event_name %>" class="w-full h-40 object-cover rounded-md mb-3" />
          
          <h3 class="text-xl font-semibold text-brand mb-2">
            <%= event.event_name %>
          </h3>

          <p class="text-sm text-gray-600">
            📅 <%= new Date(event.date_start).toLocaleDateString() %>
          </p>

          <p class="text-sm text-gray-500">
            📍 <%= event.venue_name || 'Lugar no especificado' %>
          </p>

          <p class="text-sm text-green-700 font-semibold mb-2">
            💶 
            <%= event.min_ticket_price_eur ? `€${event.min_ticket_price_eur}` : 'No disponible' %>
          </p>

          <a href="/event/<%= event.event_id %>" class="inline-block mt-2 text-sm text-white bg-accent px-4 py-2 rounded hover:bg-brand">
            Ver detalles
          </a>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<%- include('partials/footer') %>
