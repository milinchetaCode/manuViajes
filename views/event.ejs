<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= event.event_name %> - Qualy Tours</title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#1D4ED8',
            accent: '#22C55E',
            customRed: '#DC2626',
            darkGray: '#333333'
          }
        }
      }
    }
  </script>
</head>
<body class="bg-white text-gray-800 font-sans">

  <!-- Navbar -->
  <%- include('partials/header') %>

  <!-- Main Container -->
  <section class="px-4 py-12 max-w-5xl mx-auto">
    <div class="bg-white p-6 sm:p-10 rounded-2xl shadow-md border border-gray-100 space-y-8">

      <!-- Header: Image + Event Info -->
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Event Image with Overlay -->
        <div class="relative w-full h-64 rounded-2xl overflow-hidden shadow-sm border border-gray-200">
          <img 
            src="<%= event.image_url ? event.image_url : '/images/ticket.png' %>" 
            alt="<%= event.event_name %>" 
            class="w-full h-full object-cover"
          />

          <% if (event.tournament_name) { %>
            <span class="absolute top-4 left-4 bg-customRed text-white text-xs sm:text-sm font-semibold px-4 py-2 rounded-full shadow-md backdrop-blur-sm">
              <%= event.tournament_name %>
            </span>
          <% } %>
        </div>

        <!-- Event Basic Details -->
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold text-darkGray mb-4 tracking-tight">
           <%= event.event_name %>
          </h1>

          <ul class="space-y-2 text-sm sm:text-base mb-4">
            <li>
              <strong class="text-darkGray">📅 Fecha:</strong> 
              <span class="text-gray-700">
                <%= event.date_start 
                      ? new Date(event.date_start).toLocaleDateString('es-ES', { day:'2-digit', month:'short', year:'numeric' }) 
                      : 'Fecha no disponible' %>
                <% if (event.date_stop) { %>
                  - <%= new Date(event.date_stop).toLocaleDateString('es-ES', { day:'2-digit', month:'short', year:'numeric' }) %>
                <% } %>
              </span>
            </li>
            <li>
              <strong class="text-darkGray">📍 Lugar:</strong> 
              <span class="text-gray-700">
                <%= event.venue_name || 'No especificado' %>, <%= event.venue?.city || '' %>, <%= event.venue?.country || '' %>
              </span>
            </li>
          </ul>

          <% if (event.event_description) { %>
            <p class="text-gray-600 mb-4 whitespace-pre-line"><%= event.event_description %></p>
          <% } %>

          <% if (event.min_ticket_price_eur && event.max_ticket_price_eur) { %>
            <p class="text-2xl text-customRed font-bold mt-6">
              💵 Desde €<%= event.min_ticket_price_eur %> 
              hasta €<%= event.max_ticket_price_eur %>
            </p>
          <% } %>

          <!-- WhatsApp Button -->
    <a
  href="https://wa.me/5491166891154?text=<%= encodeURIComponent(
    `Hola, quiero más información sobre el evento:\n\n` +
    `Evento: ${event.event_name}\n` +
    `Fecha: ${new Date(event.date_start).toLocaleString('es-ES')}\n` +
    `Lugar: ${event.venue_name || 'No especificado'}\n` +
    (event.min_ticket_price_eur ? `Precio: desde €${event.min_ticket_price_eur}\n\n` : ``) +
    `Por favor, contáctenme para más detalles. ¡Gracias!`
  ) %>"
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center gap-3 mt-6 bg-customRed hover:bg-red-700 text-white font-semibold px-6 py-3 rounded-lg shadow-md transition-all duration-200 transform hover:scale-105"
>
  <!-- WhatsApp Icon -->
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 32 32">
    <path d="M16 .02c-8.84 0-16 7.16-16 16 0 2.82.74 5.57 2.14 7.99l-1.4 5.16 5.3-1.39c2.34 1.28 4.98 1.96 7.67 1.96h.01c8.84 0 16-7.16 16-16 0-4.27-1.66-8.29-4.69-11.31A15.896 15.896 0 0 0 16 .02zm0 29.27c-2.46 0-4.85-.66-6.95-1.91l-.5-.29-3.14.83.84-3.07-.32-.5A13.404 13.404 0 0 1 2.6 16c0-7.39 6.01-13.4 13.4-13.4 3.58 0 6.94 1.4 9.47 3.93a13.28 13.28 0 0 1 3.93 9.47c-.01 7.39-6.02 13.4-13.4 13.4zm7.49-10.08c-.41-.2-2.43-1.2-2.81-1.33-.38-.14-.66-.2-.94.2-.28.4-1.08 1.33-1.32 1.6-.24.26-.49.3-.9.1-.41-.2-1.74-.64-3.32-2.05-1.23-1.1-2.06-2.46-2.3-2.87-.24-.4-.02-.62.18-.82.18-.18.41-.49.62-.73.2-.24.27-.4.41-.68.14-.28.07-.5-.03-.7-.1-.2-.94-2.27-1.28-3.1-.34-.82-.69-.7-.94-.72-.24-.02-.52-.02-.8-.02s-.74.11-1.13.54c-.38.44-1.48 1.44-1.48 3.52 0 2.08 1.52 4.1 1.74 4.38.22.28 3 4.58 7.26 6.42.98.42 1.74.66 2.34.85.98.31 1.87.27 2.57.16.78-.12 2.43-1 2.77-1.96.34-.96.34-1.78.24-1.96-.1-.18-.38-.28-.8-.48z"/>
  </svg>

  <span>Contáctanos por WhatsApp</span>
</a>



          <!-- Email Fallback -->
          <p class="mt-4 text-sm">
            ¿No tenés WhatsApp?
            <a
              href="mailto:info@qualy.tours?subject=<%= encodeURIComponent('Consulta sobre evento: ' + event.event_name) %>&body=<%= encodeURIComponent(
                `Hola, estoy interesado en el evento:\n\n` +
                `Evento: ${event.event_name}\n` +
                `Fecha: ${new Date(event.date_start).toLocaleString('es-ES')}\n` +
                `Lugar: ${event.venue_name || 'No especificado'}\n` +
                (event.min_ticket_price_eur ? `Precio: desde €${event.min_ticket_price_eur}\n\n` : ``) +
                `Espero su respuesta. Gracias.`
              ) %>"
              class="text-customRed hover:underline"
            >
              Contáctanos por email
            </a>
          </p>
        </div>
      </div>


    <!-- Seatmap -->
<% if (event.venue_id) { %>
  <div>
    <h3 class="text-lg font-semibold text-darkGray mb-2">Mapa de asientos</h3>
    <img 
      src="https://cdn.xs2event.com/venues/<%= event.venue_id %>.svg" 
      alt="Mapa de asientos" 
      class="w-full rounded shadow-lg border border-gray-200" />
  </div>
<% } %>

      <!-- Ticket Details -->
      <% if (event.tickets && event.tickets.length > 0) { %>
        <% const filteredTickets = event.tickets
             .filter(ticket => 
               ticket.ticket_status === 'available' && 
               ticket.stock > 0 
             )
             .sort((a, b) => a.price_eur - b.price_eur); %>
      
        <div>
          <h3 class="text-lg font-semibold text-darkGray mb-2">Detalle de entradas</h3>
          <div class="overflow-y-auto max-h-[20rem] border border-gray-200 rounded divide-y divide-gray-100">
            <% if (filteredTickets.length > 0) { %>
              <% filteredTickets.forEach(ticket => { %>
                <div class="flex items-center justify-between p-3 hover:bg-gray-50 transition-all duration-200 hover:shadow-md hover:shadow-red-100">
                  
                  <!-- Left side: Category and badges -->
                  <div>
                    <p class="font-semibold text-gray-800">
                      <%= ticket.category_name %>
                      <% if (ticket.sub_category) { %> / <%= ticket.sub_category %> <% } %>
                    </p>
                    
                    <% if (ticket.category_type) { %>
                      <p class="text-gray-500 text-sm"><%= ticket.category_type %></p>
                    <% } %>
                    
                    <p class="text-gray-400 text-xs"><%= ticket.stock %> disponibles</p>
      
                    <!-- Badges -->
                    <div class="flex flex-wrap gap-1 mt-1 text-xs">
                      <% if (ticket.options) { %>
                        <% if (ticket.options.pairs_only) { %>
                          <span class="px-2 py-0.5 bg-gray-200 text-gray-700 rounded">👥 De a pares</span>
                        <% } %>
                        <% if (ticket.options.videowall) { %>
                          <span class="px-2 py-0.5 bg-gray-200 text-gray-700 rounded">🎥 Videowall</span>
                        <% } %>
                        <% if (ticket.options.covered_seat) { %>
                          <span class="px-2 py-0.5 bg-gray-200 text-gray-700 rounded">☂️ Cubierto</span>
                        <% } %>
                        <% if (ticket.options.numbered_seat) { %>
                          <span class="px-2 py-0.5 bg-gray-200 text-gray-700 rounded">🔢 Numerado</span>
                        <% } %>
                      <% } %>
                    </div>
                  </div>
      
                  <!-- Right side: Price -->
                  <div class="text-customRed font-bold text-lg whitespace-nowrap">€<%= ticket.price_eur %></div>
                </div>
              <% }) %>
            <% } else { %>
              <!-- Mensaje si no hay tickets filtrados -->
              <div class="p-4 text-center text-gray-500">
                No hay tickets disponibles
              </div>
            <% } %>
          </div>
        </div>
      <% } %>

      <!-- Google Map -->
      <% if (event.latitude && event.longitude) { %>
        <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-200">
          <iframe
            class="w-full h-64 rounded"
            frameborder="0"
            style="border:0"
            src="https://maps.google.com/maps?q=<%= event.latitude %>,<%= event.longitude %>&hl=es&z=16&output=embed"
            allowfullscreen>
          </iframe>
        </div>
      <% } %>

    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
